# Required in production
DATABASE_URL=postgres://user:password@host:5432/projex

# Production auth session resolution prefers the direct resolver first.
# Use exactly one of these production options:
#
# 1) Direct resolver module (recommended)
# Path can be absolute or relative to process cwd.
# Production example:
# BETTER_AUTH_DIRECT_SESSION_FN=./dist/server/auth/authProvider.js#getSessionFromRequest
#
# 2) BetterAuth session endpoint
# BETTER_AUTH_SESSION_URL=https://auth.example.com/api/session

# Local BetterAuth instance settings.
# Keep BETTER_AUTH_URL set for local/dev so the app can resolve same-origin auth routes.
# The direct resolver remains the preferred local setup too.
BETTER_AUTH_SECRET=replace-with-long-random-secret
BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_DIRECT_SESSION_FN=src/server/auth/authProvider.ts#getSessionFromRequest
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional invite/reset-password delivery
# Preferred: direct Resend delivery.
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
RESEND_FROM=

# Alternative: webhook delivery.
# If neither Resend nor webhook is configured, invite/reset links are logged on the server.
PROJEX_AUTH_EMAIL_WEBHOOK_URL=
PROJEX_AUTH_EMAIL_WEBHOOK_BEARER_TOKEN=
PROJEX_AUTH_RESET_REDIRECT_URL=http://localhost:5173/reset-password
PROJEX_AUTH_EMAIL_CHANGE_REDIRECT_URL=http://localhost:5173/verify-email-change

# Optional CORS allowlist for browser cross-origin requests
# Comma-separated list, e.g. https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Dev-only (must remain false/unset in production)
PROJEX_ENABLE_DEV_ENDPOINTS=false

# Smoke tooling
# Enable both of these only in local/staging environments where you want the in-app smoke UI.
# Keep both false/unset in production.
PROJEX_ENABLE_SMOKE_TOOLS=false
VITE_ENABLE_SMOKE_TOOLS=false

# Optional smoke test base URL
PROJEX_SMOKE_BASE_URL=http://localhost:5173
PROJEX_SMOKE_EMAIL=
PROJEX_SMOKE_PASSWORD=
PROJEX_SMOKE_RESET_EMAIL=
PROJEX_SMOKE_EMAIL_CHANGE_TO=
PROJEX_SMOKE_INVITE_EMAIL=
PROJEX_SMOKE_INVITE_NAME=
PROJEX_SMOKE_INVITE_ROLE=member
PROJEX_SMOKE_PRIVACY_ADMIN_EMAIL=
PROJEX_SMOKE_PRIVACY_ADMIN_PASSWORD=
PROJEX_SMOKE_PRIVACY_SUPERADMIN_EMAIL=
PROJEX_SMOKE_PRIVACY_SUPERADMIN_PASSWORD=

# Auth bootstrap/link helpers
PROJEX_AUTH_EMAIL=
PROJEX_AUTH_PASSWORD=
PROJEX_AUTH_NAME=
PROJEX_BOOTSTRAP_COMPANY_NAME=Demo Company
PROJEX_BOOTSTRAP_PROJECT_NAME=Demo Project
# Optional legacy/template-copy path:
# PROJEX_APP_TEMPLATE_USER_ID=
