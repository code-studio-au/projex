{
  "name": "projex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -b --noemit",
    "lint": "eslint .",
    "db:migrate": "node --experimental-strip-types src/server/db/migrate.ts",
    "auth:create-user": "node --experimental-strip-types src/server/auth/createAuthUser.ts",
    "auth:bootstrap-user": "node scripts/bootstrap-app-user.mjs",
    "auth:link-user": "node scripts/link-auth-user.mjs",
    "start:server": "node scripts/start-server.mjs",
    "deploy:ec2": "bash scripts/deploy-ec2.sh",
    "deploy:ec2:quick": "SKIP_INSTALL=true bash scripts/deploy-ec2.sh",
    "smoke:server": "node scripts/smoke-server.mjs",
    "cdk:install": "npm --prefix deploy/cdk install",
    "cdk:bootstrap": "npm --prefix deploy/cdk exec cdk -- bootstrap",
    "cdk:synth": "npm --prefix deploy/cdk run synth",
    "cdk:diff": "npm --prefix deploy/cdk run diff",
    "cdk:deploy": "npm --prefix deploy/cdk run deploy",
    "cdk:destroy": "npm --prefix deploy/cdk run destroy",
    "preview": "vite preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@mantine/core": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@tabler/icons-react": "^3.34.0",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-query-devtools": "^5.62.7",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/react-router-ssr-query": "^1.163.3",
    "@tanstack/react-start": "^1.164.0",
    "@tanstack/router-devtools": "^1.91.1",
    "@tanstack/router-plugin": "^1.164.0",
    "better-auth": "^1.5.1",
    "kysely": "^0.27.6",
    "mantine-react-table": "^2.0.0-beta.9",
    "nitro": "npm:nitro-nightly@^3.0.1-20260227-181935-bfbb207c",
    "pg": "^8.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/devtools-vite": "^0.5.2",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
